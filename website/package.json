{
  "private": true,
  "name": "@project-docs/website",
  "version": "1.0.0",
  "scripts": {
    "dev": "node --run generate && next dev --webpack",
    "build": "node --run generate && next build --webpack && node --run pagefind",
    "start": "serve out",
    "pagefind": "pagefind --site out/ --output-path ./public/_pagefind && cp -r ./public/_pagefind ./out",
    "next-sitemap": "next-sitemap",
    "generate": "node ./scripts/generate-website-data.mjs",
    "lint:types": "tsc"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@shikijs/transformers": "^4.3.1",
    "@vkontakte/vkui": "workspace:^",
    "@vkontakte/vkui-docs-theme": "workspace:^",
    "browserslist-vscode": "github:browserslist/browserslist-vscode",
    "next": "^16.2.10",
    "next-sitemap": "^4.2.3",
    "nextra": "^4.6.1",
    "pagefind": "^1.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-live": "^4.1.8",
    "serve": "^14.2.6",
    "slug": "^11.0.1",
    "swr": "^2.4.2",
    "typescript": "^6.0.3",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "@stackblitz/sdk": "^1.11.1",
    "lz-string": "^1.5.0"
  }
