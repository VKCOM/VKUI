{
  "files": ["types/css.d.ts", "global.vitest.ts", "vitest.setup.ts", "vitest.global-setup.ts"],
  "include": [
    "src/testing",
    "src/storybook",
    "src/**/*.test.ts*",
    "src/**/*.e2e*.ts*",
    "src/**/*.stories.ts*"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/coverage/**",
    "**/storybook-static",
    "**/__testfixtures__",
    "**/__tests__",
    "**/vkui-date-fns-tz"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2020", "dom", "dom.Iterable"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "erasableSyntaxOnly": true,
    "outDir": ".cache/ts",
    "paths": {
      "@vkui-e2e/test": ["./src/testing/e2e/index.playwright"],
      "@vkui-e2e/playground-helpers": ["./src/testing/e2e/index.playground"],
      "@vkui-e2e/utils": ["./src/testing/e2e/utils"]
    }
  }
}
