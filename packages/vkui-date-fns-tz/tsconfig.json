{
  "compilerOptions": {
    "target": "ES2018",
    "module": "NodeNext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["*.ts"],
  "exclude": ["tzOffset/", "tzScan/", "date/", "tz/", "constants/"]
}
